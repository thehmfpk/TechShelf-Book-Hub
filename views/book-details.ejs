<%- include('layouts/header') %>

<div class="max-w-6xl mx-auto px-6 py-20">
    <div class="mb-10 flex items-center gap-2 text-[10px] font-black uppercase tracking-[0.2em] text-slate-500">
        <a href="/books" class="hover:text-cyan-400 transition-colors">Library</a>
        <i class="fa-solid fa-chevron-right text-[8px]"></i>
        <span class="text-slate-300"><%= book.title %></span>
    </div>

    <div class="flex flex-col lg:flex-row gap-16 items-start">
        
        <div class="w-full lg:w-2/5 sticky top-32">
            <div class="relative group">
                <div class="absolute -inset-1 bg-gradient-to-r from-cyan-500 to-blue-600 rounded-2xl blur opacity-20 group-hover:opacity-40 transition duration-1000"></div>
                <img src="<%= book.imageUrl %>" alt="<%= book.title %>" class="relative w-full rounded-2xl border border-slate-800 shadow-2xl">
            </div>
        </div>

        <div class="w-full lg:w-3/5">
            <div class="inline-block px-3 py-1 bg-cyan-400/5 border border-cyan-400/20 rounded mb-6">
                <span class="text-[10px] font-black uppercase tracking-[0.2em] text-cyan-400">
                    <%= book.category %> // DOCUMENT_ID: <%= book._id.toString().substring(0,8) %>
                </span>
            </div>

            <h1 class="text-4xl md:text-6xl font-black text-white tracking-tighter leading-none mb-4">
                <%= book.title %>
            </h1>
            
            <p class="text-xl text-slate-400 font-medium mb-10">
                Primary Author: <span class="text-white"><%= book.author %></span>
            </p>

            <div class="space-y-8">
                <div>
                    <h4 class="text-xs font-black text-slate-500 uppercase tracking-[0.3em] mb-4">Technical Description</h4>
                    <p class="text-slate-300 text-lg leading-relaxed font-light">
                        <%= book.description %>
                    </p>
                </div>

                <div class="pt-10 border-t border-slate-900 flex flex-col sm:flex-row items-center gap-6">
                    <button onclick="openCheckoutModal('<%= book._id %>', '<%= book.title %>')" class="w-full sm:w-auto px-12 py-5 bg-cyan-500 hover:bg-white text-slate-950 font-black text-xs uppercase tracking-[0.2em] rounded-xl transition-all shadow-xl shadow-cyan-500/10">
                        Initialize Acquisition
                    </button>
                    <div class="flex items-center gap-2 text-slate-500 font-mono text-[10px] uppercase">
                        <span class="w-2 h-2 rounded-full bg-emerald-500 animate-pulse"></span>
                        Digital & Physical Stock Available
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<div id="checkoutModal" class="fixed inset-0 bg-[#030712]/95 backdrop-blur-xl z-[100] hidden items-center justify-center p-6 transition-all duration-300">
    <div class="bg-[#0a0f1d] border border-slate-800 w-full max-w-lg rounded-3xl overflow-hidden shadow-2xl">
        
        <div class="bg-slate-900/50 p-8 border-b border-slate-800 flex justify-between items-center">
            <div>
                <h2 class="text-2xl font-black text-white tracking-tight">Purchase Blueprint</h2>
                <p class="text-xs text-slate-500 mt-1 uppercase tracking-widest" id="modalBookTitle">Processing...</p>
            </div>
            <button onclick="closeCheckoutModal()" class="w-10 h-10 flex items-center justify-center rounded-full bg-slate-800 text-slate-400 hover:text-white transition-colors">&times;</button>
        </div>

        <form id="checkoutForm" onsubmit="processTransaction(event)" class="p-8 space-y-5">
            <input type="hidden" id="modalBookId">
            
            <div class="grid grid-cols-2 gap-4">
                <div class="space-y-2">
                    <label class="text-[10px] font-bold text-slate-500 uppercase tracking-widest ml-1">Full Name</label>
                    <input type="text" id="customerName" placeholder="Enter name" required class="w-full bg-[#050810] border border-slate-800 rounded-xl px-4 py-3 text-sm text-white focus:outline-none focus:border-cyan-500 transition-colors">
                </div>
                <div class="space-y-2">
                    <label class="text-[10px] font-bold text-slate-500 uppercase tracking-widest ml-1">Contact No.</label>
                    <input type="text" id="contactNumber" placeholder="+00 000 000" required class="w-full bg-[#050810] border border-slate-800 rounded-xl px-4 py-3 text-sm text-white focus:outline-none focus:border-cyan-500 transition-colors">
                </div>
            </div>

            <div class="space-y-2">
                <label class="text-[10px] font-bold text-slate-500 uppercase tracking-widest ml-1">Email Address</label>
                <input type="email" id="customerEmail" placeholder="dev@system.com" required class="w-full bg-[#050810] border border-slate-800 rounded-xl px-4 py-3 text-sm text-white focus:outline-none focus:border-cyan-500 transition-colors">
            </div>

            <div class="space-y-2">
                <label class="text-[10px] font-bold text-slate-500 uppercase tracking-widest ml-1">Delivery Address</label>
                <textarea id="address" rows="3" placeholder="Full shipping address" required class="w-full bg-[#050810] border border-slate-800 rounded-xl px-4 py-3 text-sm text-white focus:outline-none focus:border-cyan-500 transition-colors resize-none"></textarea>
            </div>

            <button type="submit" id="submitOrderBtn" class="w-full py-4 bg-gradient-to-r from-cyan-500 to-blue-600 text-slate-950 font-black text-xs uppercase tracking-[0.2em] rounded-xl hover:opacity-90 transition-all">
                Submit Purchase Data
            </button>
        </form>

        <div id="statusMessage" class="hidden mx-8 mb-8 p-4 rounded-xl text-xs font-bold text-center uppercase tracking-widest"></div>
    </div>
</div>

<script>
    function openCheckoutModal(id, title) {
        document.getElementById('modalBookId').value = id;
        document.getElementById('modalBookTitle').innerText = title;
        const modal = document.getElementById('checkoutModal');
        modal.classList.remove('hidden');
        modal.classList.add('flex');
        document.body.style.overflow = 'hidden';
    }

    function closeCheckoutModal() {
        const modal = document.getElementById('checkoutModal');
        modal.classList.add('hidden');
        modal.classList.remove('flex');
        document.body.style.overflow = 'auto';
    }

    async function processTransaction(e) {
        e.preventDefault();
        const btn = document.getElementById('submitOrderBtn');
        const status = document.getElementById('statusMessage');
        
        btn.disabled = true;
        btn.innerText = "Transmitting to MongoDB...";

        const payload = {
            bookId: document.getElementById('modalBookId').value,
            customerName: document.getElementById('customerName').value,
            customerEmail: document.getElementById('customerEmail').value,
            contactNumber: document.getElementById('contactNumber').value,
            address: document.getElementById('address').value
        };

        try {
            const response = await fetch('/order/buy', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(payload)
            });

            const result = await response.json();

            if (result.success) {
                status.className = "mx-8 mb-8 p-4 rounded-xl text-xs font-bold text-center uppercase tracking-widest bg-emerald-500/10 text-emerald-400 border border-emerald-500/20";
                status.innerText = "Order Recorded Successfully";
                status.classList.remove('hidden');
                setTimeout(() => { closeCheckoutModal(); }, 2000);
            } else {
                throw new Error("Write failed");
            }
        } catch (err) {
            status.className = "mx-8 mb-8 p-4 rounded-xl text-xs font-bold text-center uppercase tracking-widest bg-red-500/10 text-red-400 border border-red-500/20";
            status.innerText = "System Write Error";
            status.classList.remove('hidden');
            btn.disabled = false;
        }
    }
</script>

<%- include('layouts/footer') %>