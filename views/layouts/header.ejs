    <title><%= locals.title || 'TechShelf | Core Console' %></title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body class="bg-slate-900 text-slate-100 min-h-screen flex flex-gradient flex-col">
    <nav class="bg-slate-950/80 backdrop-blur-md border-b border-slate-800 sticky top-0 z-50">
        <div class="max-w-7xl mx-auto px-6 py-4 flex justify-between items-center">
            <a href="/" class="text-2xl font-black tracking-wider bg-gradient-to-r from-cyan-400 to-indigo-500 bg-clip-text text-transparent">
                TECH<span class="text-slate-100">SHELF</span>
            </a>
            <div class="space-x-8 font-medium flex items-center">
                <a href="/" class="hover:text-cyan-400 transition-colors duration-200">Home</a>
                <a href="/books" class="hover:text-cyan-400 transition-colors duration-200">Library</a>
                
                <div class="relative group">
